<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="admin-body">
  <aside class="admin-sidebar" id="admin-sidebar">
    <div class="sidebar-header">
      <a href="/" class="sidebar-logo">iusymarket<span class="logo-dot">.</span></a>
      <span class="sidebar-label">ADMIN PANEL</span>
    </div>
    <nav class="sidebar-nav">
      <a href="/admin" class="sidebar-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
        Dashboard
      </a>
      <a href="/admin/products" class="sidebar-link active">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        Products
      </a>
      <a href="/admin/users" class="sidebar-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Users
      </a>
    </nav>
    <div class="sidebar-footer">
      <a href="/auth/logout" class="sidebar-link sidebar-logout">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
        Sign Out
      </a>
    </div>
  </aside>

  <main class="admin-main" id="admin-main">
    <header class="admin-header">
      <button class="admin-menu-toggle" id="admin-menu-toggle">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
      <h2 class="admin-page-title"><%= product ? 'Edit Product' : 'Add Product' %></h2>
      <a href="/admin/products" class="btn btn-outline btn-sm">← Back</a>
    </header>

    <% if (error && error.length > 0) { %>
      <div class="flash-message flash-error" id="flash-msg">
        <span><%= error[0] %></span>
        <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
      </div>
    <% } %>

    <div class="admin-card">
      <form action="/admin/products/<%= product ? 'edit/' + product.id : 'add' %>" method="POST" enctype="multipart/form-data" class="product-form">
        <div class="form-grid">
          <!-- Left Column -->
          <div class="form-column">
            <div class="form-group">
              <label for="name">Product Name *</label>
              <input type="text" id="name" name="name" placeholder="e.g. Nike Tech Fleece Full-Zip Hoodie" value="<%= product ? product.name : '' %>" required>
            </div>

            <div class="form-group">
              <label for="description">Description</label>
              <textarea id="description" name="description" rows="4" placeholder="Describe the product..."><%= product ? product.description || '' : '' %></textarea>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="price">Price (Rp) *</label>
                <input type="number" id="price" name="price" placeholder="e.g. 500000" value="<%= product ? product.price : '' %>" required min="0">
              </div>
              <div class="form-group">
                <label for="category">Category</label>
                <select id="category" name="category">
                  <option value="Nike Tech Fleece" <%= product && product.category === 'Nike Tech Fleece' ? 'selected' : '' %>>Nike Tech Fleece</option>
                  <option value="Nike Tech Fleece Hoodie" <%= product && product.category === 'Nike Tech Fleece Hoodie' ? 'selected' : '' %>>Nike Tech Fleece Hoodie</option>
                  <option value="Nike Tech Fleece Jogger" <%= product && product.category === 'Nike Tech Fleece Jogger' ? 'selected' : '' %>>Nike Tech Fleece Jogger</option>
                  <option value="Nike Tech Fleece Jacket" <%= product && product.category === 'Nike Tech Fleece Jacket' ? 'selected' : '' %>>Nike Tech Fleece Jacket</option>
                  <option value="Other" <%= product && product.category === 'Other' ? 'selected' : '' %>>Other</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="condition_status">Condition</label>
              <select id="condition_status" name="condition_status">
                <option value="New" <%= product && product.condition_status === 'New' ? 'selected' : '' %>>New (Brand New)</option>
                <option value="Like New" <%= product && product.condition_status === 'Like New' ? 'selected' : '' %>>Like New</option>
                <option value="Very Good" <%= product && product.condition_status === 'Very Good' ? 'selected' : '' %>>Very Good</option>
                <option value="Good" <%= product && product.condition_status === 'Good' ? 'selected' : '' %>>Good</option>
                <option value="Fair" <%= product && product.condition_status === 'Fair' ? 'selected' : '' %>>Fair</option>
              </select>
            </div>
          </div>

          <!-- Right Column -->
          <div class="form-column">
            <!-- Image Upload -->
            <div class="form-group">
              <label>Product Image</label>
              <div class="image-upload-area" id="image-upload-area">
                <% if (product && product.image) { %>
                  <img src="/uploads/<%= product.image %>" alt="" class="image-preview" id="image-preview">
                  <p class="image-upload-text">Click or drag to replace image</p>
                <% } else { %>
                  <div class="image-preview-placeholder" id="image-preview-placeholder">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#999" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                    <p>Click or drag to upload image</p>
                    <span>JPG, PNG, WebP (max 5MB)</span>
                  </div>
                <% } %>
                <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/webp,image/gif" class="image-input">
              </div>
            </div>

            <!-- Gallery Images -->
            <div class="form-group">
              <label>Gallery Images (up to 5)</label>
              <% if (gallery && gallery.length > 0) { %>
                <div class="admin-gallery-grid">
                  <% gallery.forEach(img => { %>
                    <div class="admin-gallery-item">
                      <img src="/uploads/<%= img.filename %>" alt="">
                      <form action="/admin/products/delete-image/<%= img.id %>" method="POST" class="inline-form">
                        <button type="submit" class="admin-gallery-delete" title="Remove">&times;</button>
                      </form>
                    </div>
                  <% }) %>
                </div>
              <% } %>
              <div style="margin-top:8px">
                <input type="file" name="gallery" multiple accept="image/jpeg,image/png,image/webp,image/gif" style="padding:8px;border:1px dashed #2a2a2a;border-radius:8px;width:100%;color:#888;background:#111;font-size:.85rem">
                <span style="font-size:.72rem;color:#555;margin-top:4px;display:block">Select multiple images. Existing gallery images will be kept.</span>
              </div>
            </div>

            <!-- Sizes -->
            <div class="form-group">
              <label>Available Sizes</label>
              <div class="dynamic-fields" id="sizes-container">
                <% if (sizes && sizes.length > 0) { %>
                  <% sizes.forEach(size => { %>
                    <div class="dynamic-field">
                      <input type="text" name="sizes" value="<%= size.size %>" placeholder="e.g. S, M, L, XL">
                      <button type="button" class="remove-field-btn" onclick="this.parentElement.remove()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      </button>
                    </div>
                  <% }) %>
                <% } %>
              </div>
              <button type="button" class="add-field-btn" onclick="addField('sizes-container', 'sizes', 'e.g. S, M, L, XL')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Size
              </button>
            </div>

            <!-- Defects -->
            <div class="form-group">
              <label>Minus / Defects</label>
              <div class="dynamic-fields" id="defects-container">
                <% if (defects && defects.length > 0) { %>
                  <% defects.forEach(defect => { %>
                    <div class="dynamic-field">
                      <input type="text" name="defects" value="<%= defect.description %>" placeholder="e.g. Minor scratch on zipper">
                      <button type="button" class="remove-field-btn" onclick="this.parentElement.remove()">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                      </button>
                    </div>
                  <% }) %>
                <% } %>
              </div>
              <button type="button" class="add-field-btn" onclick="addField('defects-container', 'defects', 'e.g. Minor scratch on zipper')">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Defect Note
              </button>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <a href="/admin/products" class="btn btn-outline">Cancel</a>
          <button type="submit" class="btn btn-primary">
            <%= product ? 'Update Product' : 'Add Product' %>
          </button>
        </div>
      </form>
    </div>
  </main>

  <script src="/js/admin.js"></script>
</body>
</html>
