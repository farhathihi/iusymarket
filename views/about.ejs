<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="About iusymarket - Your trusted source for premium Nike Tech Fleece collection in Indonesia.">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <%- include('partials/navbar') %>

  <% if (success && success.length > 0) { %>
    <div class="flash-message flash-success" id="flash-msg">
      <span><%= success[0] %></span>
      <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
  <% } %>
  <% if (error && error.length > 0) { %>
    <div class="flash-message flash-error" id="flash-msg">
      <span><%= error[0] %></span>
      <button class="flash-close" onclick="this.parentElement.remove()">&times;</button>
    </div>
  <% } %>

  <!-- About Hero -->
  <section class="page-hero">
    <div class="container">
      <span class="page-hero-label animate-fade-up">ABOUT US</span>
      <h1 class="page-hero-title animate-fade-up delay-1">iusymarket<span class="logo-dot">.</span></h1>
      <p class="page-hero-subtitle animate-fade-up delay-2">Your trusted destination for premium Nike Tech Fleece</p>
    </div>
  </section>

  <!-- About Content -->
  <section class="about-content section-padding">
    <div class="container">
      <div class="about-grid">
        <div class="about-text scroll-reveal">
          <span class="section-label">OUR STORY</span>
          <h2>Who We Are</h2>
          <p>Welcome to <strong>iusymarket</strong> — your go-to destination for premium Nike Tech Fleece jackets and hoodies in Indonesia. We are passionate about streetwear and committed to bringing you only the finest, most authentic Nike Tech Fleece pieces.</p>
          <p>Founded with a vision to make premium sportswear accessible, we carefully curate each item in our collection to ensure quality, authenticity, and style. Whether you're looking for a brand-new piece or a pre-loved gem, we've got you covered.</p>
          <p>At iusymarket, customer satisfaction is our top priority. We believe in transparency — every product listing includes detailed condition notes, available sizes, and fair pricing.</p>
        </div>

        <div class="about-stats scroll-reveal">
          <div class="stat-card">
            <span class="stat-number" data-count="500">0</span>
            <span class="stat-plus">+</span>
            <span class="stat-label">Products Sold</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-count="300">0</span>
            <span class="stat-plus">+</span>
            <span class="stat-label">Happy Customers</span>
          </div>
          <div class="stat-card">
            <span class="stat-number" data-count="100">0</span>
            <span class="stat-plus">%</span>
            <span class="stat-label">Authentic</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="values-section section-padding">
    <div class="container">
      <div class="section-header scroll-reveal">
        <span class="section-label">WHY CHOOSE US</span>
        <h2 class="section-title">Our Values</h2>
      </div>
      <div class="values-grid">
        <div class="value-card scroll-reveal">
          <div class="value-number">01</div>
          <h3>Authenticity</h3>
          <p>Every product is verified for authenticity. We never compromise on quality.</p>
        </div>
        <div class="value-card scroll-reveal">
          <div class="value-number">02</div>
          <h3>Transparency</h3>
          <p>Detailed product descriptions including any defects or wear, so you know exactly what you're getting.</p>
        </div>
        <div class="value-card scroll-reveal">
          <div class="value-number">03</div>
          <h3>Customer First</h3>
          <p>Responsive support via WhatsApp and Instagram. We're always here to help.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="contact-section section-padding" id="contact">
    <div class="container">
      <div class="section-header scroll-reveal">
        <span class="section-label">GET IN TOUCH</span>
        <h2 class="section-title">Contact Us</h2>
        <p class="section-subtitle">Have questions? Reach out through any of our channels</p>
      </div>

      <div class="contact-grid">
        <a href="https://wa.me/6285691913965" target="_blank" class="contact-card scroll-reveal">
          <div class="contact-icon whatsapp-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
          </div>
          <h3>WhatsApp</h3>
          <p>+62 856-9191-3965</p>
          <span class="contact-cta">Chat Now →</span>
        </a>

        <a href="https://www.instagram.com/iusymarket" target="_blank" class="contact-card scroll-reveal">
          <div class="contact-icon instagram-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          </div>
          <h3>Instagram</h3>
          <p>@iusymarket</p>
          <span class="contact-cta">Follow Us →</span>
        </a>

        <a href="https://www.tiktok.com/@ig.iusymarket" target="_blank" class="contact-card scroll-reveal">
          <div class="contact-icon tiktok-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1 0-5.78 2.92 2.92 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 3 15.57 6.33 6.33 0 0 0 9.37 22a6.33 6.33 0 0 0 6.33-6.33V9.19a8.16 8.16 0 0 0 4.84 1.58v-3.4a4.85 4.85 0 0 1-.95-.68z"/></svg>
          </div>
          <h3>TikTok</h3>
          <p>@ig.iusymarket</p>
          <span class="contact-cta">Watch Us →</span>
        </a>

        <a href="mailto:iusymarket@gmail.com" class="contact-card scroll-reveal">
          <div class="contact-icon email-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <h3>Email</h3>
          <p>iusymarket@gmail.com</p>
          <span class="contact-cta">Send Email →</span>
        </a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="/js/main.js"></script>
</body>
</html>
